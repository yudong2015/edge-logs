#!/bin/bash
# Edge Logs Helm 部署命令
# 使用方法: ./edge-helm [action] [env] [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CHART_DIR="${SCRIPT_DIR}/helm/edge-logs"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 显示使用帮助
show_help() {
    cat << EOF
Edge Logs Helm 部署工具

用法:
  $0 <action> [env] [options]

Actions:
  deploy      部署到指定环境
  upgrade     升级现有部署
  status      查看部署状态
  logs        查看组件日志
  rollback    回滚部署
  uninstall   卸载部署
  template    生成K8s模板（dry-run）
  test        运行Helm测试
  help        显示此帮助

环境:
  dev         开发环境 (默认)
  staging     预发环境
  prod        生产环境

选项:
  --tag TAG           覆盖镜像标签
  --component COMP    指定组件 (对logs有效: apiserver,frontend,clickhouse)
  --values FILE       额外的values文件
  --set KEY=VALUE     设置单个值
  --namespace NS      覆盖目标命名空间
  --timeout DURATION  操作超时时间 (默认: 300s)
  --wait              等待部署完成
  --dry-run           只显示将要执行的命令
  --debug             开启调试模式

示例:
  $0 deploy dev                              # 部署到开发环境
  $0 deploy staging --tag v1.0.0             # 部署v1.0.0到预发环境
  $0 upgrade prod --set apiserver.image.tag=v1.0.1  # 升级生产环境APIServer
  $0 status dev                              # 查看开发环境状态
  $0 logs dev --component apiserver          # 查看APIServer日志
  $0 template dev --dry-run                  # 生成开发环境模板
  $0 rollback prod --wait                    # 回滚生产环境并等待完成
  $0 uninstall dev                          # 卸载开发环境

GitHub镜像构建:
  GitHub Actions会自动构建镜像并推送到 quanzhenglong/edge:TAG
  部署时会从该仓库拉取对应的镜像标签

EOF
}

# 解析命令行参数
parse_args() {
    ACTION="${1:-help}"
    ENV="${2:-dev}"

    shift 2 2>/dev/null || shift $# # 移除已处理的参数

    # 默认值
    CUSTOM_TAG=""
    COMPONENT="all"
    CUSTOM_VALUES=""
    SET_VALUES=()
    CUSTOM_NAMESPACE=""
    TIMEOUT="300s"
    WAIT_FLAG=""
    DRY_RUN=false
    DEBUG_FLAG=""

    # 解析选项
    while [[ $# -gt 0 ]]; do
        case $1 in
            --tag)
                CUSTOM_TAG="$2"
                shift 2
                ;;
            --component)
                COMPONENT="$2"
                shift 2
                ;;
            --values)
                CUSTOM_VALUES="$2"
                shift 2
                ;;
            --set)
                SET_VALUES+=("$2")
                shift 2
                ;;
            --namespace)
                CUSTOM_NAMESPACE="$2"
                shift 2
                ;;
            --timeout)
                TIMEOUT="$2"
                shift 2
                ;;
            --wait)
                WAIT_FLAG="--wait"
                shift
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            --debug)
                DEBUG_FLAG="--debug"
                shift
                ;;
            *)
                log_error "未知选项: $1"
                show_help
                exit 1
                ;;
        esac
    done
}

# 检查依赖
check_dependencies() {
    if ! command -v helm &> /dev/null; then
        log_error "helm 未安装，请安装 Helm"
        exit 1
    fi

    if ! command -v kubectl &> /dev/null; then
        log_error "kubectl 未安装，请安装 kubectl"
        exit 1
    fi

    if [[ ! -d "$CHART_DIR" ]]; then
        log_error "Helm chart 不存在: $CHART_DIR"
        exit 1
    fi
}

# 获取release名称
get_release_name() {
    echo "edge-logs-$ENV"
}

# 获取命名空间
get_namespace() {
    if [[ -n "$CUSTOM_NAMESPACE" ]]; then
        echo "$CUSTOM_NAMESPACE"
    else
        case $ENV in
            dev) echo "edge-logs-dev" ;;
            staging) echo "edge-logs-staging" ;;
            prod) echo "edge-logs" ;;
            *) echo "edge-logs-$ENV" ;;
        esac
    fi
}

# 获取values文件
get_values_files() {
    local values_files=()

    # 基础values文件
    values_files+=("-f" "$CHART_DIR/values.yaml")

    # 环境特定的values文件
    local env_values="${SCRIPT_DIR}/helm/values-${ENV}.yaml"
    if [[ -f "$env_values" ]]; then
        values_files+=("-f" "$env_values")
    fi

    # 自定义values文件
    if [[ -n "$CUSTOM_VALUES" ]]; then
        if [[ -f "$CUSTOM_VALUES" ]]; then
            values_files+=("-f" "$CUSTOM_VALUES")
        else
            log_error "自定义values文件不存在: $CUSTOM_VALUES"
            exit 1
        fi
    fi

    echo "${values_files[@]}"
}

# 构建Helm命令
build_helm_command() {
    local action="$1"
    local release_name=$(get_release_name)
    local namespace=$(get_namespace)
    local values_files=($(get_values_files))

    local cmd="helm $action"

    if [[ "$action" == "install" || "$action" == "upgrade" ]]; then
        cmd="$cmd $release_name $CHART_DIR"
    else
        cmd="$cmd $release_name"
    fi

    # 添加通用选项
    cmd="$cmd --namespace $namespace"
    cmd="$cmd --timeout $TIMEOUT"

    if [[ "$action" == "install" ]]; then
        cmd="$cmd --create-namespace"
    fi

    # 添加values文件
    cmd="$cmd ${values_files[*]}"

    # 添加自定义标签覆盖
    if [[ -n "$CUSTOM_TAG" ]]; then
        cmd="$cmd --set apiserver.image.tag=$CUSTOM_TAG"
        cmd="$cmd --set frontend.image.tag=$CUSTOM_TAG"
    fi

    # 添加set值
    for set_val in "${SET_VALUES[@]}"; do
        cmd="$cmd --set $set_val"
    done

    # 添加其他标志
    if [[ -n "$WAIT_FLAG" ]]; then
        cmd="$cmd $WAIT_FLAG"
    fi

    if [[ -n "$DEBUG_FLAG" ]]; then
        cmd="$cmd $DEBUG_FLAG"
    fi

    echo "$cmd"
}

# 执行命令 (支持dry-run)
execute() {
    local cmd="$1"
    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "DRY-RUN: $cmd"
    else
        log_info "执行: $cmd"
        eval "$cmd"
    fi
}

# 检查release是否存在
release_exists() {
    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    helm list -n "$namespace" | grep -q "$release_name"
}

# 部署操作
action_deploy() {
    log_info "准备部署 Edge Logs 到 $ENV 环境..."

    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    if release_exists; then
        log_info "Release $release_name 已存在，执行升级..."
        local cmd=$(build_helm_command "upgrade")
    else
        log_info "首次安装 Release $release_name..."
        local cmd=$(build_helm_command "install")
    fi

    execute "$cmd"

    if [[ "$DRY_RUN" != "true" ]]; then
        log_success "部署完成!"
        action_status
    fi
}

# 升级操作
action_upgrade() {
    log_info "准备升级 $ENV 环境..."

    if ! release_exists; then
        log_error "Release 不存在，请使用 deploy 命令首次安装"
        exit 1
    fi

    local cmd=$(build_helm_command "upgrade")
    execute "$cmd"

    if [[ "$DRY_RUN" != "true" ]]; then
        log_success "升级完成!"
    fi
}

# 状态检查
action_status() {
    log_info "检查 $ENV 环境状态..."

    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    log_info "Helm Release 状态:"
    execute "helm status $release_name -n $namespace"

    echo ""
    log_info "Pod 状态:"
    execute "kubectl get pods -n $namespace -l app.kubernetes.io/instance=$release_name -o wide"

    echo ""
    log_info "Service 状态:"
    execute "kubectl get svc -n $namespace -l app.kubernetes.io/instance=$release_name"
}

# 查看日志
action_logs() {
    log_info "查看 $ENV 环境 $COMPONENT 组件日志..."

    local namespace=$(get_namespace)
    local release_name=$(get_release_name)

    case $COMPONENT in
        apiserver)
            execute "kubectl logs -n $namespace -l app.kubernetes.io/instance=$release_name,app.kubernetes.io/component=apiserver -f --tail=100"
            ;;
        frontend)
            execute "kubectl logs -n $namespace -l app.kubernetes.io/instance=$release_name,app.kubernetes.io/component=frontend -f --tail=100"
            ;;
        clickhouse)
            execute "kubectl logs -n $namespace -l app.kubernetes.io/instance=$release_name,app.kubernetes.io/component=clickhouse -f --tail=100"
            ;;
        all|*)
            log_info "显示所有组件日志..."
            execute "kubectl logs -n $namespace -l app.kubernetes.io/instance=$release_name -f --tail=50"
            ;;
    esac
}

# 回滚操作
action_rollback() {
    log_info "准备回滚 $ENV 环境..."

    if ! release_exists; then
        log_error "Release 不存在，无法回滚"
        exit 1
    fi

    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    # 显示历史版本
    log_info "Release 历史版本:"
    execute "helm history $release_name -n $namespace"

    # 回滚到前一个版本
    local cmd="helm rollback $release_name -n $namespace --timeout $TIMEOUT"
    if [[ -n "$WAIT_FLAG" ]]; then
        cmd="$cmd $WAIT_FLAG"
    fi

    execute "$cmd"

    if [[ "$DRY_RUN" != "true" ]]; then
        log_success "回滚完成!"
    fi
}

# 卸载操作
action_uninstall() {
    log_info "准备卸载 $ENV 环境..."

    if ! release_exists; then
        log_warn "Release 不存在，跳过卸载"
        return 0
    fi

    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    # 生产环境需要确认
    if [[ "$ENV" == "prod" ]]; then
        log_warn "⚠️  即将卸载生产环境! 这将删除所有数据!"
        read -p "请输入 'YES' 确认: " confirm
        if [[ "$confirm" != "YES" ]]; then
            log_info "操作已取消"
            return 0
        fi
    fi

    local cmd="helm uninstall $release_name -n $namespace --timeout $TIMEOUT"
    execute "$cmd"

    if [[ "$DRY_RUN" != "true" ]]; then
        log_success "卸载完成!"

        # 询问是否删除PVC
        read -p "是否删除持久化数据 (PVC)? [y/N]: " delete_pvc
        if [[ "$delete_pvc" =~ ^[Yy]$ ]]; then
            execute "kubectl delete pvc -n $namespace -l app.kubernetes.io/instance=$release_name"
            log_success "持久化数据已删除"
        fi
    fi
}

# 生成模板
action_template() {
    log_info "生成 $ENV 环境 K8s 模板..."

    local cmd=$(build_helm_command "template")
    execute "$cmd"
}

# 运行测试
action_test() {
    log_info "运行 $ENV 环境测试..."

    local release_name=$(get_release_name)
    local namespace=$(get_namespace)

    local cmd="helm test $release_name -n $namespace --timeout $TIMEOUT"
    execute "$cmd"
}

# 主函数
main() {
    parse_args "$@"

    check_dependencies

    case $ACTION in
        deploy)
            action_deploy
            ;;
        upgrade)
            action_upgrade
            ;;
        status)
            action_status
            ;;
        logs)
            action_logs
            ;;
        rollback)
            action_rollback
            ;;
        uninstall)
            action_uninstall
            ;;
        template)
            action_template
            ;;
        test)
            action_test
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "未知操作: $ACTION"
            show_help
            exit 1
            ;;
    esac
}

# 执行主函数
main "$@"