#!/bin/bash
# Edge Logs 一键部署命令
# 使用方法: ./edge-deploy [action] [env] [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 显示使用帮助
show_help() {
    cat << EOF
Edge Logs 部署工具

用法:
  $0 <action> [env] [options]

Actions:
  deploy    部署到指定环境
  status    查看部署状态
  logs      查看组件日志
  rollback  回滚部署
  clean     清理环境 (危险操作)
  health    健康检查
  help      显示此帮助

环境:
  dev       开发环境 (默认)
  staging   预发环境
  prod      生产环境

选项:
  --tag TAG        指定镜像标签
  --component COMP 指定组件 (对logs/rollback有效)
  --force          强制执行操作
  --dry-run        只显示将要执行的命令

示例:
  $0 deploy dev                    # 部署到开发环境
  $0 deploy staging --tag v1.0.0   # 部署v1.0.0到预发环境
  $0 status dev                    # 查看开发环境状态
  $0 logs dev --component apiserver # 查看APIServer日志
  $0 health dev                    # 健康检查
  $0 rollback dev                  # 回滚开发环境
  $0 clean dev --force             # 强制清理开发环境

EOF
}

# 解析命令行参数
parse_args() {
    ACTION="${1:-help}"
    ENV="${2:-dev}"

    shift 2 2>/dev/null || shift $# # 移除已处理的参数

    # 默认值
    IMAGE_TAG=""
    COMPONENT="all"
    FORCE=false
    DRY_RUN=false

    # 解析选项
    while [[ $# -gt 0 ]]; do
        case $1 in
            --tag)
                IMAGE_TAG="$2"
                shift 2
                ;;
            --component)
                COMPONENT="$2"
                shift 2
                ;;
            --force)
                FORCE=true
                shift
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            *)
                log_error "未知选项: $1"
                show_help
                exit 1
                ;;
        esac
    done
}

# 执行命令 (支持dry-run)
execute() {
    local cmd="$1"
    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "DRY-RUN: $cmd"
    else
        log_info "执行: $cmd"
        eval "$cmd"
    fi
}

# 部署操作
action_deploy() {
    log_info "准备部署到 $ENV 环境..."

    local cmd="cd $SCRIPT_DIR && make deploy ENV=$ENV"
    if [[ -n "$IMAGE_TAG" ]]; then
        cmd="$cmd IMAGE_TAG=$IMAGE_TAG"
    fi

    execute "$cmd"
}

# 状态检查
action_status() {
    log_info "检查 $ENV 环境状态..."
    execute "cd $SCRIPT_DIR && make status ENV=$ENV"
}

# 查看日志
action_logs() {
    log_info "查看 $ENV 环境 $COMPONENT 组件日志..."
    execute "cd $SCRIPT_DIR && make logs ENV=$ENV COMPONENT=$COMPONENT"
}

# 回滚操作
action_rollback() {
    if [[ "$ENV" == "prod" && "$FORCE" != "true" ]]; then
        log_error "生产环境回滚需要 --force 参数确认"
        exit 1
    fi

    log_warn "准备回滚 $ENV 环境 $COMPONENT 组件..."
    execute "cd $SCRIPT_DIR && make rollback ENV=$ENV COMPONENT=$COMPONENT"
}

# 清理环境
action_clean() {
    if [[ "$FORCE" != "true" ]]; then
        log_error "清理操作需要 --force 参数确认 (这将删除整个命名空间!)"
        exit 1
    fi

    log_warn "准备清理 $ENV 环境 (删除命名空间)..."
    execute "cd $SCRIPT_DIR && make clean ENV=$ENV"
}

# 健康检查
action_health() {
    log_info "执行 $ENV 环境健康检查..."

    local namespace=""
    case $ENV in
        dev) namespace="edge-logs-dev" ;;
        staging) namespace="edge-logs-staging" ;;
        prod) namespace="edge-logs" ;;
        *)
            log_error "未知环境: $ENV"
            exit 1
            ;;
    esac

    log_info "检查Pod状态..."
    execute "kubectl get pods -n $namespace -o wide"

    log_info "检查服务状态..."
    execute "kubectl get svc -n $namespace"

    if [[ "$DRY_RUN" != "true" ]]; then
        log_info "执行连通性测试..."

        # ClickHouse健康检查
        if kubectl get pod clickhouse-0 -n $namespace &>/dev/null; then
            if kubectl exec -n $namespace clickhouse-0 -- clickhouse-client --query "SELECT 1" &>/dev/null; then
                log_success "ClickHouse: 健康"
            else
                log_error "ClickHouse: 不健康"
            fi
        else
            log_warn "ClickHouse: Pod不存在"
        fi

        # APIServer健康检查 (如果使用真实镜像)
        if kubectl get deployment edge-logs-apiserver -n $namespace &>/dev/null; then
            local api_ready=$(kubectl get deployment edge-logs-apiserver -n $namespace -o jsonpath='{.status.readyReplicas}')
            if [[ "$api_ready" -gt 0 ]]; then
                log_success "APIServer: $api_ready Pod(s) 就绪"
            else
                log_error "APIServer: 无就绪Pod"
            fi
        else
            log_warn "APIServer: Deployment不存在"
        fi

        # Frontend健康检查
        if kubectl get deployment edge-logs-frontend -n $namespace &>/dev/null; then
            local fe_ready=$(kubectl get deployment edge-logs-frontend -n $namespace -o jsonpath='{.status.readyReplicas}')
            if [[ "$fe_ready" -gt 0 ]]; then
                log_success "Frontend: $fe_ready Pod(s) 就绪"
            else
                log_error "Frontend: 无就绪Pod"
            fi
        else
            log_warn "Frontend: Deployment不存在"
        fi
    fi
}

# 主函数
main() {
    parse_args "$@"

    case $ACTION in
        deploy)
            action_deploy
            ;;
        status)
            action_status
            ;;
        logs)
            action_logs
            ;;
        rollback)
            action_rollback
            ;;
        clean)
            action_clean
            ;;
        health)
            action_health
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "未知操作: $ACTION"
            show_help
            exit 1
            ;;
    esac
}

# 执行主函数
main "$@"