# API Configuration
# Production: Leave empty to use nginx proxy (recommended for Kubernetes deployment)
# Development: Set to http://localhost:8080 for direct backend access during local development
VITE_API_BASE_URL=
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_QUERY_HISTORY=true
VITE_ENABLE_AUTO_COMPLETE=true

# UI Configuration
VITE_DEFAULT_PAGE_SIZE=50
VITE_MAX_PAGE_SIZE=500
VITE_QUERY_DEBOUNCE_MS=300
